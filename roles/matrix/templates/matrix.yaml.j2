---
apiVersion: v1
kind: Pod
metadata:
  name: matrix
  labels:
    app: matrix
spec:
  containers:
    - name: synapse
      image: {{ synapse_image }}:{{ synapse_version }}
      ports:
        - containerPort: 8008
          hostPort: {{ synapse_port }}
{% if synapse_enable_federation %}
        - containerPort: 8448
          hostPort: {{ synapse_federation_port }}
{% endif %}
      env:
        - name: SYNAPSE_CONFIG_PATH
          value: /data/homeserver.yaml
        - name: TZ
          value: "{{ matrix_timezone }}"
      volumeMounts:
        - name: localtime
          mountPath: /etc/localtime
          readOnly: true
        - name: synapse-data
          mountPath: /data
      livenessProbe:
        httpGet:
          path: /health
          port: 8008
        initialDelaySeconds: 30
        periodSeconds: 30
        timeoutSeconds: 10
        failureThreshold: 3
      restartPolicy: Never

    - name: element
      image: {{ element_image }}:{{ element_version }}
      ports:
        - containerPort: 80
          hostPort: 8080
      volumeMounts:
        - name: element-config
          mountPath: /app/config.json
          subPath: config.json
      restartPolicy: Never

  volumes:
    - name: localtime
      hostPath:
        path: /etc/localtime
        type: File
    - name: synapse-data
      hostPath:
        path: {{ synapse_data_dir }}
        type: Directory
    - name: element-config
      hostPath:
        path: {{ element_data_dir }}
        type: Directory
